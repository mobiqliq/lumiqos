# Auth Service — Environment Variables
# Copy this file to .env and fill in real values before starting the service.
# NEVER commit .env — it is in .gitignore.

# --- Database ---
DB_HOST=xceliqos_db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=xceliq

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_64_byte_random_hex_string
JWT_EXPIRES_IN=7d

# --- Service ---
AUTH_SERVICE_PORT=3002
NODE_ENV=development

# --- Logging ---
# Options: error, warn, info, debug (default: debug in dev, info in prod)
LOG_LEVEL=debug
