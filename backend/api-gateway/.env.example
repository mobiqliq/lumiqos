# API Gateway — Environment Variables
# Copy this file to .env and fill in real values before starting the service.
# NEVER commit .env — it is in .gitignore.

# --- Auth ---
# Must match auth-service JWT_SECRET exactly
JWT_SECRET=CHANGE_ME_generate_a_64_byte_random_hex_string

# --- Downstream Service Routing ---
SCHOOL_SERVICE_HOST=school-service
SCHOOL_SERVICE_PORT=3000
AUTH_SERVICE_HOST=auth-service
AUTH_SERVICE_PORT=3002
AI_SERVICE_HOST=ai-service
AI_SERVICE_PORT=3005
BILLING_SERVICE_HOST=billing-service
BILLING_SERVICE_PORT=3006

# --- Service ---
API_GATEWAY_PORT=3000
NODE_ENV=development

# --- Logging ---
# Options: error, warn, info, debug (default: debug in dev, info in prod)
LOG_LEVEL=debug
