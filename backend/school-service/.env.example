# School Service — Environment Variables
# Copy this file to .env and fill in real values before starting the service.
# NEVER commit .env — it is in .gitignore.

# --- Database ---
DB_HOST=xceliqos_db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=xceliq

# --- Auth ---
# Must match auth-service JWT_SECRET exactly
JWT_SECRET=CHANGE_ME_generate_a_64_byte_random_hex_string

# --- AI Keys (school-service LLM calls) ---
# Primary: OpenAI gpt-4o-mini
OPENAI_API_KEY=CHANGE_ME_sk-proj-...
# Fallback: Anthropic claude-haiku
ANTHROPIC_API_KEY=CHANGE_ME_sk-ant-api03-...

# --- Service ---
SCHOOL_SERVICE_PORT=3000
TCP_MICROSERVICE_PORT=3001
NODE_ENV=development
