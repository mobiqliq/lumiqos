# AI Service — Environment Variables
# Copy this file to .env and fill in real values before starting the service.
# NEVER commit .env — it is in .gitignore.

# --- Database ---
DB_HOST=xceliqos_db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=xceliq

# --- AI Keys (ai-service TCP microservice) ---
# Primary: OpenAI gpt-4o-mini
OPENAI_API_KEY=CHANGE_ME_sk-proj-...
# Fallback: Anthropic claude-haiku
ANTHROPIC_API_KEY=CHANGE_ME_sk-ant-api03-...

# --- Service ---
AI_SERVICE_PORT=3005
NODE_ENV=development
