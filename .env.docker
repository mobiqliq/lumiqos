# Docker Environment Variables for LumiqOS
# Used by docker-compose.yml

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=lumiq
DATABASE_PASSWORD=lumiq
DATABASE_NAME=lumiqos

# Service-level env var names (used by TypeORM configs)
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=lumiq
DB_PASSWORD=lumiq
DB_DATABASE=lumiqos
