{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "ES2023",
    "baseUrl": "./",
    "paths": {
      "@lumiqos/shared": ["backend/shared/src/index.ts"],
      "@lumiqos/shared/*": ["backend/shared/src/*"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true
  },
  "exclude": ["node_modules", "**/dist"]
}
